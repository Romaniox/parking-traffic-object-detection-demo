# Backend API base URL used at build time (Vite).
# Empty / unset => same origin (local dev via proxy, or all-in-one server deploy).
# When the frontend is hosted separately (e.g. Cloudflare Workers), set this to
# the backend's public HTTPS URL so API calls reach the server:
#   VITE_API_BASE=https://api.your-domain.example
VITE_API_BASE=
