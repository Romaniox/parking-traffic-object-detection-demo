# Backend configuration (see backend/app/config.py)

# Root data directory: models/, images/, db/ all live here.
DATA_DIR=backend/data

# Max accepted upload size in bytes (default 10 MB).
MAX_UPLOAD_BYTES=10485760

# Detection backend: "yolo" for the real model, "stub" for a model-free dev run.
MODEL_NAME=yolo

# Path to YOLO weights inside DATA_DIR/models/.
MODEL_WEIGHTS=backend/data/models/yolo26l.pt

# Caddy site address — controls TLS mode:
#   localhost  -> local HTTPS via internal CA (default)
#   :80        -> plain HTTP, reachable over LAN
#   example.com -> automatic Let's Encrypt certificate
SITE_ADDRESS=localhost
